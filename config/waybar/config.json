{
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "´ćů",
      "´äĹ"
    ],
    "min-length": 6,
    "on-scroll-down": "brightnessctl set 1%-",
    "on-scroll-up": "brightnessctl set 1%+"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-alt": "{time} {icon}",
    "format-charging": "´çŽ {capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ],
    "format-plugged": "´çŽ {capacity}%",
    "states": {
      "critical": 20,
      "good": 95,
      "warning": 30
    }
  },

  "clock": {
    "format": "´ÇŚ {:%R  %d/%m}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "cpu": {
    "format": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ´őŤ",
    "format-icons": [
      "Ôľü",
      "Ôľé",
      "Ôľâ",
      "Ôľä",
      "Ôľů",
      "Ôľć",
      "Ôľç",
      "Ôľł"
    ],
    "interval": 1
  },

  "custom/weather": {
    "exec": "python3 ~/.config/waybar/scripts/waybar-wttr.py",
    "format": "{}",
    "interval": 30,
    "return-type": "json",
    "tooltip": true
  },

  "hyprland/window": {
    "format": "<span font='9' rise='-4444'>{}</span>",
    "max-length": 200,
    "seperate-outputs": true
  },

  "hyprland/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "on-click": "activate"
  },

  "memory": {
    "format": "{used:0.1f}G/{total:0.1f}G ´âë",
    "interval": 30
  },
  
  "network": {
    "format": "{ifname}",
    "format-disconnected": "",
    "format-ethernet": " ˇ░łü ",
    "format-wifi": "{essid} ´çź"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": {
      "car": "´ć╣",
      "default": [
        "´ÇŽ",
        "´Çž",
        "´ÇĘ"
      ],
      "hands-free": "´Çą",
      "headphone": "´Çą",
      "headset": "´Çą",
      "phone": "´éĽ",
      "portable": "´éĽ"
    },
    "format-muted": "´ÇŽ Muted",
    "on-click": "pamixer -t",
    "on-scroll-down": "pamixer -d 5",
    "on-scroll-up": "pamixer -i 5",
    "scroll-step": 5,
    "tooltip": false
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "´ä░ {volume}%",
    "format-source-muted": "´ä▒ Muted",
    "on-click": "pamixer --default-source -t",
    "on-scroll-down": "pamixer --default-source -d 5",
    "on-scroll-up": "pamixer --default-source -i 5",
    "scroll-step": 5
  },

  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C ´őë",
    "format-critical": "{temperatureC}┬░C ´őç",
    "hwmon-path": [
      "/sys/class/hwmon/hwmon2/temp1_input",
      "/sys/class/thermal/thermal_zone0/temp"
    ],
    "thermal-zone": 2
  },

  "tray": {
    "icon-size": 13,
    "spacing": 10
  }
}
